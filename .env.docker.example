# Безопасные настройки для Docker (демо без внешнего API).
# Для реального AI: скопируйте в .env.docker (файл в .gitignore), задайте ключи, PPC_FORCE_DEMO_AI=false.
# copy .env.docker.example .env.docker

DATABASE_URL=sqlite:///data/app.db
LOG_LEVEL=INFO

UPLOAD_DIR=./app/uploads
EXPORT_DIR=app/exports

PPC_FORCE_DEMO_AI=true

AI_PRIMARY_PROVIDER=anthropic
AI_FALLBACK_PROVIDER=openai
AI_ENABLE_FALLBACK=true
AI_FORCE_JSON_RESPONSE_FORMAT=true
REQUIRE_AI_CONSENT=true
AI_DEFAULT_EXCLUDE_REVENUE=true
AI_DEFAULT_EXCLUDE_CONTACTS=true

AI_TEMPERATURE_ANALYSIS=0.3
AI_TEMPERATURE_CP=0.7
AI_TEMPERATURE_IDEAS=0.8
AI_ANALYSIS_MAX_TOKENS=8192

KNOWLEDGE_BASE_ENABLED=true
KNOWLEDGE_BASE_USE_LOCAL_EMBEDDINGS=true
EMBEDDING_PROVIDER=local_hash
VECTOR_DB_PROVIDER=chroma
CHROMA_PERSIST_DIR=./data/chroma

# OCR: в образе есть Tesseract; для сдачи достаточно disabled
OCR_PROVIDER=disabled

CORS_ORIGINS=*

# Ключи — только в локальном .env.docker (не коммитить):
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
