# База данных
DATABASE_URL=sqlite:///data/app.db

# Логи в консоль: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=DEBUG

# === AI Model Router (транспорт: ProxyAPI — https://proxyapi.ru/docs) ===
# Один ключ ProxyAPI обычно кладут в OPENAI_API_KEY и ANTHROPIC_API_KEY.
# Основной сценарий: Claude/Anthropic primary + OpenAI-compatible fallback.
# Если ключи не заданы или оставлены пустыми, приложение работает в бесплатном демо-режиме.
# M1: AI_TRANSPORT=native | proxyapi_unified (см. полный репозиторий PPC Audit Workspace)
AI_PRIMARY_PROVIDER=anthropic
AI_FALLBACK_PROVIDER=openai
AI_ENABLE_FALLBACK=true
AI_REQUEST_TIMEOUT_SECONDS=120

# Anthropic / Claude primary (ProxyAPI в РФ: https://proxyapi.ru/docs)
ANTHROPIC_API_KEY=
ANTHROPIC_API_URL=https://api.proxyapi.ru/anthropic
ANTHROPIC_MODEL=claude-opus-4-5
ANTHROPIC_VERSION=2023-06-01

# OpenAI fallback + embeddings через ProxyAPI (один ключ ProxyAPI в OPENAI_API_KEY)
OPENAI_API_KEY=
OPENAI_API_URL=https://api.proxyapi.ru/openai/v1/chat/completions
OPENAI_FALLBACK_MODEL=gpt-4o-mini
OPENAI_EMBEDDINGS_API_URL=https://api.proxyapi.ru/openai/v1/embeddings

# Backward-compatible (те же URL ProxyAPI)
AI_API_KEY=
AI_API_URL=https://api.proxyapi.ru/openai/v1/chat/completions
AI_MODEL=gpt-4o

# M1: выбор модели и оценка стоимости (₽ + USD)
AI_TRANSPORT=native
AI_ALLOW_DIRECT_PROVIDER=false
AI_USD_TO_RUB_RATE=92.0
PROXYAPI_UNIFIED_API_URL=https://openai.api.proxyapi.ru/v1/chat/completions

# === Knowledge base / Retrieval feedback loop ===
KNOWLEDGE_BASE_ENABLED=true
VECTOR_DB_PROVIDER=chroma
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=ppc_audit_confirmed_findings
KNOWLEDGE_BASE_TOP_K=3
# false = искать по всей базе; true = сначала фильтровать строго по нише
KNOWLEDGE_BASE_FILTER_BY_NICHE=false

# Embeddings. Для продакшена используйте OpenAI text-embedding-3-small.
# Для офлайн-демо/тестов можно поставить EMBEDDING_PROVIDER=local_hash или KNOWLEDGE_BASE_USE_LOCAL_EMBEDDINGS=true.
# pytest автоматически включает PPC_FORCE_DEMO_AI и локальные embeddings (см. tests/conftest.py).
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
KNOWLEDGE_BASE_USE_LOCAL_EMBEDDINGS=false

# M2.13 — KB в чате (дополнение к KNOWLEDGE_BASE_*)
CHAT_KB_TOP_K=3
CHAT_KB_MAX_DISTANCE=0.55

# Блокировать платные вызовы ProxyAPI (pytest ставит true автоматически)
PPC_FORCE_DEMO_AI=false

# Загрузки
UPLOAD_DIR=./app/uploads
MAX_UPLOAD_SIZE=52428800

# CORS. Для MVP можно оставить *, для продакшена перечислите домены через запятую.
CORS_ORIGINS=*

# Папка для PDF-экспортов
EXPORT_DIR=app/exports

# Google Slides export (опционально)
# Если не задано, приложение всё равно делает PPTX, который можно загрузить в Google Slides вручную.
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_DRIVE_FOLDER_ID=

# Speech-to-text стратегия: manual | web_speech | external_stt | server_stt | local_whisper
STT_PROVIDER=manual

# Privacy / consent
AI_PROVIDER_NAME=Model Router: Claude primary + OpenAI fallback
AI_PROVIDER_PRIVACY_URL=
AI_FORCE_JSON_RESPONSE_FORMAT=true
REQUIRE_AI_CONSENT=true
AI_DEFAULT_EXCLUDE_REVENUE=true
AI_DEFAULT_EXCLUDE_CONTACTS=true
REQUIRE_WEB_SPEECH_CONSENT=true

# Local Whisper STT (optional, heavy)
LOCAL_WHISPER_MODEL=small
LOCAL_WHISPER_DEVICE=cpu

# AI temperature modes
AI_TEMPERATURE_ANALYSIS=0.3
AI_TEMPERATURE_CP=0.7
AI_TEMPERATURE_IDEAS=0.8
AI_TEMPERATURE_MIN=0.0
AI_TEMPERATURE_MAX=1.0
AI_ANALYSIS_MAX_TOKENS=8192

# Feedback loop: использовать исправления маркетолога в повторном анализе
FEEDBACK_LOOP_ENABLED=true
FEEDBACK_LOOP_MAX_EXAMPLES=5

# Ops-алерты (staging/production): webhook или Telegram при сбоях analyze/PDF
OPS_ALERTS_ENABLED=false
OPS_ALERT_MIN_SEVERITY=warning
OPS_ALERT_COOLDOWN_SECONDS=900
OPS_ALERT_WEBHOOK_URL=
OPS_TELEGRAM_BOT_TOKEN=
OPS_TELEGRAM_CHAT_ID=

# Тесты pytest
TEST_BASE_URL=http://localhost:8000

# Отображение дат в списке аудитов (UTC в БД не меняется)
DISPLAY_TIMEZONE=Europe/Moscow
DISPLAY_TZ_SUFFIX=UTC+3

# OCR скриншотов (winget install UB-Mannheim.TesseractOCR)
OCR_PROVIDER=tesseract_cli
OCR_TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
OCR_TESSDATA_PREFIX=./data/tessdata
OCR_TESSERACT_LANG=rus+eng
OCR_TIMEOUT_SECONDS=30
OCR_MIN_TEXT_LENGTH=20
