# Безопасный пример .env для отправки преподавателю (без секретов)

DATABASE_URL=sqlite:///data/app.db

# AI (ключи оставлены пустыми)
AI_PRIMARY_PROVIDER=anthropic
AI_FALLBACK_PROVIDER=openai
AI_ENABLE_FALLBACK=true
AI_REQUEST_TIMEOUT_SECONDS=120

ANTHROPIC_API_KEY=
ANTHROPIC_API_URL=https://api.proxyapi.ru/anthropic
ANTHROPIC_MODEL=claude-opus-4-5
ANTHROPIC_VERSION=2023-06-01

OPENAI_API_KEY=
OPENAI_API_URL=https://api.proxyapi.ru/openai/v1/chat/completions
OPENAI_FALLBACK_MODEL=gpt-4o-mini
OPENAI_EMBEDDINGS_API_URL=https://api.proxyapi.ru/openai/v1/embeddings

PPC_FORCE_DEMO_AI=true

# Runtime
UPLOAD_DIR=./app/uploads
EXPORT_DIR=app/exports
MAX_UPLOAD_SIZE=52428800
CORS_ORIGINS=*

# OCR (локально на Windows)
OCR_PROVIDER=tesseract_cli
OCR_TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
OCR_TESSDATA_PREFIX=C:\PPC-Audit-Clean\data\tessdata
OCR_TESSERACT_LANG=rus+eng
OCR_TIMEOUT_SECONDS=30
